<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(255,255,255,0.3);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(255,255,255,0.1);stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Decorative waves pattern -->
  <path d="M0 100 Q 50 50, 100 100 T 200 100" stroke="url(#grad1)" stroke-width="3" fill="none"/>
  <path d="M0 120 Q 50 70, 100 120 T 200 120" stroke="url(#grad1)" stroke-width="3" fill="none"/>
  <path d="M0 140 Q 50 90, 100 140 T 200 140" stroke="url(#grad1)" stroke-width="3" fill="none"/>
  
  <!-- Decorative circles -->
  <circle cx="150" cy="50" r="30" fill="url(#grad1)"/>
  <circle cx="180" cy="80" r="20" fill="url(#grad1)"/>
  <circle cx="170" cy="110" r="15" fill="url(#grad1)"/>
</svg>
